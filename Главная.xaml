<Page x:Class="реклама.Главная"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Главная"
      Background="#0F172A">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#0F172A"
                              Offset="0"/>
                <GradientStop Color="#FF3A1E3B"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="300"
                 Height="300"
                 Fill="#FFBE92CB"
                 Opacity="0.25"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-100,-100,0,0"/>

        <Ellipse Width="250"
                 Height="250"
                 Fill="#FF0C040C"
                 Opacity="0.2"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-80,-80"/>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="720">

            <TextBlock Text="ПремиумБанк"
                       Foreground="White"
                       FontSize="38"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,15"/>

            <TextBlock Text="«Ваше доверие — наш главный капитал»"
                       Foreground="#CBD5E1"
                       FontSize="18"
                       TextAlignment="Center"
                       Margin="0,0,0,40"/>

            <WrapPanel HorizontalAlignment="Center"
                       Margin="0,0,0,40">

                <Border Width="210"
                        Height="220"
                        Margin="10"
                        CornerRadius="15"
                        Background="#FF3A1E3B"
                        Padding="20">

                    <StackPanel>



                        <TextBlock Text="Наши услуги"
                                   FontSize="19"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="В этом разделе представлены все основные услуги банка — кредиты, депозиты, карты и онлайн-банкинг. Узнайте, как мы можем помочь вам легко и удобно управлять финансами."
                                   Foreground="#CBD5E1"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Width="210"
                        Height="220"
                        Margin="10"
                        CornerRadius="15"
                        Background="#FF3A1E3B"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="Акции"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,15" Height="40"/>

                        <TextBlock Text="следите за последними акциями, выгодными предложениями и бонусами. Получите максимум от сотрудничества с нашим банком."
                                   Foreground="#CBD5E1"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
     
                <Border Width="210"
                        Height="220"
                        Margin="10"
                        CornerRadius="15"
                        Background="#FF3A1E3B"
                        Padding="20">

                    <StackPanel>



                        <TextBlock Text="Обратная связь и поддержка"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   Margin="0,0,0,15" TextWrapping="Wrap"/>

                        <TextBlock Text="Нужна помощь или консультация? Свяжитесь с нашей службой поддержки через чат, по телефону или через форму обратной связи. Мы всегда готовы вам помочь.."
                                   Foreground="#CBD5E1"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </WrapPanel>


            <Button Content="Перейти к объектам"
                    Width="260"
                    Height="60"
                    FontSize="22"
                    FontWeight="Bold"
                    Background="#FFB3A3B4"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,30"
                    Click="Button_Click">

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#3B82F6"/>
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#1D4ED8"/>
                            </Trigger>

                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Grid>
</Page>
